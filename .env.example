# Conferly Environment Variables

# ============================================================
# SUPABASE (Required - Already configured in source)
# ============================================================
# DO NOT commit these to version control
# They are embedded in src/lib/supabase.ts

# ============================================================
# LIVEKIT CLOUD (REQUIRED FOR VIDEO)
# ============================================================

# LiveKit server URL (WebSocket)
# Format: wss://your-project.lky.dev
VITE_LIVEKIT_URL=wss://your-livekit-project.lky.dev

# ============================================================
# SUPABASE EDGE FUNCTION SECRETS (Set via CLI)
# ============================================================

# These must be set in Supabase dashboard or via CLI:
# supabase secrets set LIVEKIT_API_KEY=your_key
# supabase secrets set LIVEKIT_API_SECRET=your_secret
# supabase secrets set LIVEKIT_URL=wss://your-project.lky.dev

# ============================================================
# GETTING LIVEKIT CREDENTIALS
# ============================================================

# 1. Go to https://livekit.io
# 2. Create account / Sign in
# 3. Create new project
# 4. Go to Settings → API Keys
# 5. Copy:
#    - API Key → LIVEKIT_API_KEY
#    - API Secret → LIVEKIT_API_SECRET  
#    - Server URL → LIVEKIT_URL

# ============================================================
# OPTIONAL: TRANSLATION SERVICE
# ============================================================

# MyMemory translation is free (no key needed)
# Uses: https://api.mymemory.translated.net/get

# ============================================================
# OPTIONAL: TURN SERVERS
# ============================================================

# LiveKit provides built-in TURN
# No additional configuration needed