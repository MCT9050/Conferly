# Conferly Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Required variables must be set for the app to function
# ============================================================

# ============================================================
# REQUIRED - Supabase Configuration
# ============================================================

# Supabase Project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# REQUIRED - Server Only (NOT exposed to client)
# ============================================================

# Supabase Service Role Key (from Project Settings → API)
# WARNING: Never expose this to the client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# OPTIONAL - LiveKit (for video conferencing)
# ============================================================

# LiveKit URL (from LiveKit Cloud dashboard)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API Key (from LiveKit Cloud dashboard)
LIVEKIT_API_KEY=your-livekit-api-key

# LiveKit API Secret (from LiveKit Cloud dashboard)
# WARNING: Never expose this to the client!
LIVEKIT_API_SECRET=your-livekit-api-secret

# ============================================================
# OPTIONAL - Cloudflare Turnstile (for spam protection)
# ============================================================

# Turnstile Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key